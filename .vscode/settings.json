{
  "files.exclude": {
    "_ignore_*.*": true,
    "_ignore_*": true,
    ".agents": true,
    ".AI": true,
    ".codex": true,
    ".dockerignore": true,
    ".eslintignore": true,
    ".eslintrc.json": true,
    ".eslintrc*": true,
    ".github": true,
    ".gitignore": true,
    ".husky": true,
    ".huskyrc": true,
    ".ignore_*.*": true,
    ".ignore_*": true,
    ".lintstagedrc": true,
    ".npmignore": true,
    ".npmrc": true,
    ".nvmrc": true,
    ".prettierignore": true,
    ".prettierrc": true,
    ".prettierrc*": true,
    ".scannerwork": true,
    ".tools": true,
    ".vscode": true,
    "**/.env": true,
    "**/.env[.-]*": true,
    "**/.git": true,
    "**/dist": true,
    "**/package-lock.json": true,
    "**/tsconfig*": true,
    "AGENTS.md": true,
    "commitlint.config.*": true,
    "CONTRIBUTING.md": true,
    "coverage": true,
    "dist": true,
    "docs": true,
    "GITFLOW.md": true,
    "LICENSE": true,
    "node_modules": true,
    "package-lock.json": true,
    "PLANS.md": true,
    "README.*md": true
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/*/**": true,
    "/coverage/**": true,
    "/.scannerwork/**": true,
    ".husky": true
  },
  "editor.tabSize": 4,
  "editor.formatOnSave": false,
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  }
}